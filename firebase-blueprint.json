{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user profile information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created" }
      },
      "required": ["uid", "email"]
    },
    "conversions": {
      "title": "Code Conversion",
      "description": "Stores history of code conversions performed by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique conversion ID" },
        "userId": { "type": "string", "description": "ID of the user who performed the conversion" },
        "sourceFormat": { "type": "string", "description": "Format of the input code" },
        "targetFormat": { "type": "string", "description": "Format of the output code" },
        "inputCode": { "type": "string", "description": "The raw input code" },
        "outputCode": { "type": "string", "description": "The converted output code" },
        "status": { "type": "string", "enum": ["success", "failed"], "description": "Status of the conversion" },
        "errorMessage": { "type": "string", "description": "Error message if conversion failed" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the conversion was performed" }
      },
      "required": ["id", "userId", "sourceFormat", "targetFormat", "inputCode", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile data"
    },
    "/conversions/{conversionId}": {
      "schema": "conversions",
      "description": "Code conversion history"
    }
  }
}
